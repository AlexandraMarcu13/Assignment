{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./out-tsc/spec",
    "types": [
      "jasmine",
      "node"
    ],
    "esModuleInterop": true,
    "module": "CommonJS",
    "target": "ES2022",
    "moduleResolution": "node",
    "allowJs": true,
    "checkJs": false,
    "lib": ["ES2022", "dom"]
  },
  "files": [
    "src/test.ts"
  ],
  "include": [
    "src/**/*.spec.ts",
    "src/**/*.d.ts"
  ]
}